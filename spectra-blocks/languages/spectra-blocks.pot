#: src/components/container-layout-guide/index.js:54
msgid "Container Layout Guide Flow Layout"
msgstr ""

#: src/components/container-layout-guide/index.js:58
msgid "Flow Layout"
msgstr ""

#: src/components/container-layout-guide/index.js:61
msgid "Arrange blocks in a natural <b>top-to-bottom</b> order, with minimal layout controls. Best for simple, readable content and quick layouts with simple content stacking."
msgstr ""

#: src/components/container-layout-guide/index.js:75
msgid "Container Layout Guide Flex Layout"
msgstr ""

#: src/components/container-layout-guide/index.js:79
msgid "Flex Layout"
msgstr ""

#: src/components/container-layout-guide/index.js:82
msgid "Arrange blocks <b>horizontally or vertically</b>, adjust their alignment, and allow them to wrap onto multiple lines. Justification controls how blocks are spaced and aligned."
msgstr ""

#: src/components/container-layout-guide/index.js:96
msgid "Container Layout Guide Grid Layout"
msgstr ""

#: src/components/container-layout-guide/index.js:100
msgid "Grid Layout"
msgstr ""

#: src/components/container-layout-guide/index.js:103
msgid "Grid layout arranges blocks into <b>rows and columns</b>, giving you precise control over where each item appears. You can set a minimum column width and adjust individual item positions."
msgstr ""

#: src/components/container-layout-guide/index.js:117
msgid "Container Layout Guide Constrained Layout"
msgstr ""

#: src/components/container-layout-guide/index.js:121
msgid "Constrained Layout"
msgstr ""

#: src/components/container-layout-guide/index.js:124
msgid "Constrained layout <b>keeps your content centered</b> and limits how wide it can grow. Even on large screens, content stays comfortable to read and visually balanced."
msgstr ""

#: src/components/container-layout-guide/index.js:138
msgid "Container Layout Guide Understanding Layout Changes"
msgstr ""

#: src/components/container-layout-guide/index.js:142
msgid "Understanding Layout Changes"
msgstr ""

#: src/components/container-layout-guide/index.js:145
msgid "You can always change layout type from the <b>Sidebar → Layout Settings</b>. Each layout type offers different controls and behaviour."
msgstr ""

#: src/components/container-layout-guide/index.js:156
msgid "You can also use the <b>Change Layout</b> <img /> option from the toolbar to change layout variation/style."
msgstr ""

#: src/components/container-layout-guide/index.js:167
msgid "Note:"
msgstr ""

#: src/components/container-layout-guide/index.js:169
msgid "When you choose a column layout styles like Two Columns or Three Columns, the editor switches to Grid automatically. Grid keeps columns aligned and evenly spaced, so you don't have to adjust anything manually."
